# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.txt text eol=lf
*.markdown text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Archives
*.7z binary
*.jar binary
*.rar binary
*.tar.gz binary
*.tgz binary

# Fonts
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary

